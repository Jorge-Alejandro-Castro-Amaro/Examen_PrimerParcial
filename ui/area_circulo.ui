   <string notr="true">/* --- Ventana principal del diálogo --- */
QDialog {
background-color: #1e1e1e; /* fondo oscuro */
color: #f1f1f1;
font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
font-size: 14px;
}

/* --- Etiquetas --- */
QLabel {
color: #f1f1f1;
font-size: 13px;
font-weight: bold;
}

/* --- Campos de entrada --- */
QLineEdit {
background-color: #2c2c2c;
color: #ffffff;
border: 1px solid #555;
border-radius: 4px;
padding: 4px;
}

QLineEdit:focus {
border: 1px solid #0078d7; /* azul al enfocarse */
}

/* --- Botón Calcular --- */
QPushButton {
background-color: #0078d7; /* azul estilo Windows */
color: #ffffff;
border-radius: 4px;
padding: 6px 12px;
font-weight: bold;
}

QPushButton:hover {
background-color: #005a9e; /* azul más oscuro al pasar el mouse */
}

QPushButton:pressed {
background-color: #004578; /* azul profundo al hacer clic */
}

/* --- Resultado (label) --- */
#lbl_resultado {
color: #00ff88; /* verde llamativo para el resultado */
font-size: 14px;
font-weight: bold;
}
</string>
