  <property name="styleSheet">
   <string notr="true">/* --- Ventana principal --- */
QMainWindow {
    background-color: #1e1e1e;   /* fondo oscuro */
    color: #f1f1f1;
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 14px;
}

/* --- Barra de menú --- */
QMenuBar {
    background-color: #2c2c2c;
    color: #ffffff;
    font-weight: bold;
    padding: 4px;
}

QMenuBar::item:selected {
    background-color: #3a3a3a;
    border-radius: 4px;
}

/* --- Menús desplegables --- */
QMenu {
    background-color: #2c2c2c;
    border: 1px solid #444;
    color: #f1f1f1;
    font-size: 13px;
}

QMenu::item {
    padding: 6px 20px;
}

QMenu::item:selected {
    background-color: #0078d7;   /* azul estilo Windows */
    color: #ffffff;
}

/* --- Botones --- */
QPushButton {
    background-color: #0078d7;
    color: #ffffff;
    border-radius: 4px;
    padding: 6px 12px;
}

QPushButton:hover {
    background-color: #005a9e;
}

/* --- Etiquetas --- */
QLabel {
    color: #f1f1f1;
    font-size: 13px;
}

/* --- Campos de texto --- */
QLineEdit {
    background-color: #2c2c2c;
    color: #ffffff;
    border: 1px solid #555;
    border-radius: 4px;
    padding: 4px;
}

QLineEdit:focus {
    border: 1px solid #0078d7;
}
</string>
